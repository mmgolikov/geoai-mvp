NEXT_PUBLIC_MAPBOX_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MODEL_DECISION_SCORING=
NEXT_PUBLIC_SUPABASE_URL=
# Public browser-safe key. Legacy anon keys are not accepted by application runtime.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_AUTH_MODE=demo_public
GEOAI_ACCESS_ENFORCEMENT_MODE=soft
GEOAI_REQUIRE_SUPABASE_READY=false
GEOAI_REQUIRE_STORAGE_READY=false
GEOAI_ALLOW_DEMO_PUBLIC=true
# Server-only; a key alone never activates upstream use and pre-AUTH generation still returns 403.
GEOAI_ALLOW_OPENAI_UPSTREAM=false
GEOAI_ENABLE_PREVIEW_SOURCE_PACK=false
# Required with the flag above; operator-only, 32+ random characters, never NEXT_PUBLIC_*.
GEOAI_OPERATOR_SOURCE_TOKEN=

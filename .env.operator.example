# Operator/worker or trusted-terminal variables only.
# Never configure this file's values in the public GeoAI Vercel application.
# Copy to .env.operator (gitignored) only in the trusted operator terminal.
GEOAI_OPERATOR_SUPABASE_URL=
GEOAI_OPERATOR_SUPABASE_DB_URL=
GEOAI_OPERATOR_SUPABASE_SECRET_KEY=
GEOAI_OPERATOR_EXPECTED_PROJECT_REF=
GEOAI_OPERATOR_PARENT_PROJECT_REF=pphdqkurxneyagvnnjdt
GEOAI_ALLOW_SUPABASE_TARGET=
# Format: <action>:<project-ref>:<git-head>:<canonical-migration-tree-sha>
GEOAI_OPERATOR_TARGET_APPROVAL=
# Format: write:<action>:<project-ref>
GEOAI_OPERATOR_WRITE_CONFIRMATION=
# Formats: backup:<project-ref>:<receipt> and rollback:<project-ref>:<receipt>
GEOAI_OPERATOR_BACKUP_RECEIPT=
GEOAI_OPERATOR_ROLLBACK_RECEIPT=
# Format: repair:20260705100000:<project-ref>
GEOAI_OPERATOR_PRELEDGER_REPAIR_RECEIPT=
GEOAI_ALLOW_SUPABASE_MIGRATION_APPLY=false
GEOAI_CONFIRM_SUPABASE_MIGRATION_APPLY=
GEOAI_ALLOW_STORAGE_WRITE_TEST=false
GEOAI_EVIDENCE_DEPLOYMENT_SHA=
GEOAI_STORAGE_SIGNED_URL_VERIFIED=false
GEOAI_STORAGE_LAST_VERIFIED_AT=
GEOAI_AUDIT_WRITE_READ_VERIFIED=false
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=

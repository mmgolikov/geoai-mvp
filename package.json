{
  "name": "geoai-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "GeoAI MVP skeleton for spatial decision intelligence.",
  "scripts": {
    "dev": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev -H 127.0.0.1",
    "dev:turbo": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev -H 127.0.0.1 --turbopack",
    "build": "next build",
    "ingest:dld": "node scripts/ingest-dld-sample.mjs",
    "ingest:dld:real": "node scripts/ingest-dld-dubai-pulse.mjs",
    "ingest:dld:public": "node scripts/ingest-public-data.mjs dld-public",
    "ingest:dld:snapshot": "node scripts/ingest-dld-snapshot.mjs",
    "ingest:open-geodata": "node scripts/ingest-open-geodata-sample.mjs",
    "ingest:osm:real": "node scripts/ingest-osm-geofabrik.mjs",
    "ingest:osm:public": "node scripts/ingest-public-data.mjs osm-public",
    "ingest:osm:snapshot": "node scripts/ingest-osm-snapshot.mjs",
    "ingest:overture:public": "node scripts/ingest-public-data.mjs overture-public",
    "ingest:worldpop:public": "node scripts/ingest-public-data.mjs worldpop-public",
    "ingest:admin-boundaries:public": "node scripts/ingest-public-data.mjs admin-boundaries-public",
    "ingest:public-data:all": "node scripts/ingest-public-data.mjs all",
    "data:status": "node scripts/data-status.mjs",
    "validate:external-data": "node scripts/data-status.mjs --validate",
    "supabase:migrate:check": "node scripts/check-supabase-migration.mjs",
    "supabase:migrate:apply": "node scripts/apply-supabase-migration.mjs",
    "supabase:seed:pilot-foundation": "node scripts/seed-pilot-foundation.mjs",
    "supabase:verify:persistence": "node scripts/verify-durable-persistence.mjs",
    "start": "next start",
    "lint": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "mapbox-gl": "^3.11.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}

{
  "schemaVersion": "1.0",
  "authorityType": "repository_release_policy",
  "policyOwner": "GeoAI Release Engineering",
  "repositoryRole": "policy_schema_and_historical_evidence",
  "currentOperationalAuthority": "external_post_release_evidence",
  "authorityPrecedence": [
    "github_default_branch_and_merge_state",
    "github_deployments_or_production_environment",
    "vercel_production_alias",
    "project_hub_post_release_receipt",
    "repository_historical_snapshot"
  ],
  "repositoryCiCapabilities": {
    "validatesPolicyAndSnapshotSchema": true,
    "validatesHistoricalCurrentDistinction": true,
    "queriesLiveGithubState": false,
    "queriesLiveVercelState": false,
    "mayDeclareCurrentOperationalRuntime": false
  },
  "requiredPostReleaseEvidenceFields": [
    "verifiedAt",
    "mergedPullRequest",
    "mainSha",
    "qualityGateRunId",
    "productionDeploymentId",
    "productionUrl",
    "productionStatus",
    "routeSmoke",
    "runtimeLogInspection",
    "dataHonestyCaveat"
  ],
  "snapshotRules": {
    "requiredAuthorityType": "historical_last_verified_snapshot",
    "supersededWhenNewerReleaseExists": true,
    "mustNeverBeLabelledCurrent": true,
    "externalReceiptMaySupersede": true
  },
  "maturityClaimsForbidden": [
    "production-ready",
    "pilot-ready"
  ],
  "requiredCaveat": "Screening hypothesis; official validation required; not a legal, cadastral, zoning, planning or valuation conclusion."
}
